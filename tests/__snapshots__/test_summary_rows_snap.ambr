  \multicolumn{2}{l}{Sum} & 6 & 60 \\
  \multicolumn{2}{l}{Mean} & 2.0 & 20.0 \\
  B & r4 & 4 & 40 \\
   & r5 & 5 & 50 \\
   & r6 & 6 & 60 \\
  \midrule\addlinespace[2.5pt]
  \multicolumn{2}{l}{Sum} & 15 & 150 \\
  \multicolumn{2}{l}{Mean} & 5.0 & 50.0 \\
  '''
